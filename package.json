{
  "name": "whyops-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-dev.mjs",
    "build": "tsx scripts/generate-pseo-snapshot.ts && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "pages:build": "tsx scripts/generate-pseo-snapshot.ts && next build && npx @cloudflare/next-on-pages",
    "pages:preview": "pnpm pages:build && wrangler pages dev",
    "pages:deploy": "pnpm pages:build && wrangler pages deploy"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.453.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-ascii-text": "^0.0.4",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "3.4.16",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "wrangler": "^4.78.0"
  }
}
